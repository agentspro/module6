# OpenAI API Key (Required)
OPENAI_API_KEY=sk-your-openai-api-key-here

# LangChain Tracing (Optional)
# CrewAI uses LangChain internally, so LangSmith tracing works automatically
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your-langsmith-api-key-here
LANGCHAIN_PROJECT=crewai-agents

# Real API Integrations (Required for tools)
# OpenWeatherMap API - Free tier available
# Sign up at: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key-here


# CrewAI Configuration
CREWAI_TELEMETRY=false

# ============================================================================
# OBSERVABILITY PLATFORMS (Optional)
# ============================================================================

# Phoenix Arize - Open-source observability (Recommended for CrewAI)
# Run Phoenix server: python -m phoenix.server.main serve
# UI available at: http://localhost:6006
# Install: pip install arize-phoenix openinference-instrumentation-crewai
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_PROJECT_NAME=crewai-agents

# LangFuse - Open-source/Cloud observability (Great for production)
# Sign up at: https://cloud.langfuse.com or self-host
# Install: pip install langfuse openlit
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com
