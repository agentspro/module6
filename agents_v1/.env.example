# OpenAI API Key (Required)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# LangSmith Configuration (Required for tracing)
# Sign up at: https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__your-langsmith-api-key-here
LANGCHAIN_PROJECT=langchain-v1-agents

# Real API Integrations (Required for agent tools)
# OpenWeatherMap API - Free tier available
# Sign up at: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key-here


# Optional: Set endpoint if using different LangSmith instance
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ============================================================================
# OBSERVABILITY PLATFORMS (Optional)
# ============================================================================

# Phoenix Arize - Open-source observability (Optional)
# Run Phoenix server: python -m phoenix.server.main serve
# UI available at: http://localhost:6006
# Install: pip install arize-phoenix openinference-instrumentation-langchain
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_PROJECT_NAME=langchain-agents

# LangFuse - Open-source/Cloud observability (Optional)
# Sign up at: https://cloud.langfuse.com or self-host
# Install: pip install langfuse
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# Guardrails AI - Hub validators (Optional)
# Sign up at: https://hub.guardrailsai.com
# Install validators: guardrails hub install hub://guardrails/toxic_language
GUARDRAILS_API_KEY=your-guardrails-api-key-here
